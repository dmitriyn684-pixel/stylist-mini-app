{
  "name": "stylist-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "brandbook:capture": "node scripts/capture-brandbook-visuals.mjs",
    "brandbook:pdf": "python scripts/generate_brandbook_pdf.py",
    "brandbook:v2": "python scripts/generate_brandbook_v2.py",
    "brandbook:visual": "python scripts/generate_visual_brandbook_pdf.py",
    "brandbook:assets": "python scripts/optimize_portfolio_assets.py",
